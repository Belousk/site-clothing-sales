# Скопируйте файл в `.env` и при необходимости измените значения.

# По умолчанию используется SQLite — БД создаётся автоматически в backend/clothing_sales.db
DATABASE_URL=sqlite:///./clothing_sales.db

# Для PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/clothing_sales

# Секрет для подписи сессий. В продакшене используйте длинную случайную строку.
SECRET_KEY=change-me-in-production-please-use-long-random-string
