# Скопируйте в .env и подправьте под себя.
# Этот файл читает docker compose (см. docker-compose.yml).

# На каком порту хоста публиковать фронт (открывайте http://127.0.0.1:<этот порт>).
FRONTEND_PORT=8080

# Идентификация и сессии
APP_NAME=Maison Couture
# Сгенерируйте свой секрет: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=dev-secret-please-change
SESSION_MAX_AGE=1209600

# По умолчанию — SQLite в volume backend_data:
DATABASE_URL=sqlite:////app/data/clothing_sales.db

# Пример для PostgreSQL (поднимать с `--profile postgres`):
# DATABASE_URL=postgresql+psycopg2://app:app@db:5432/clothing_sales
# POSTGRES_DB=clothing_sales
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
